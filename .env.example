# Firebase Configuration
# Get these values from your Firebase Console: https://console.firebase.google.com/
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Google OAuth
# Get these from Google Cloud Console or Firebase Authentication settings
GOOGLE_IOS_CLIENT_ID=your_ios_client_id.apps.googleusercontent.com
GOOGLE_WEB_CLIENT_ID=your_web_client_id.apps.googleusercontent.com
GOOGLE_REVERSED_CLIENT_ID=com.googleusercontent.apps.your_client_id

# Quran Foundation API.
# Two credential pairs because QF splits content and user features by env:
#   - Content credentials go to PRODUCTION (full mushaf available).
#   - User credentials go to PRE-LIVE (full auth/user features) until production
#     OAuth scopes are approved.
QF_CONTENT_CLIENT_ID=your_qf_production_client_id
QF_CONTENT_CLIENT_SECRET=your_qf_production_client_secret
QF_CONTENT_OAUTH_BASE=https://oauth2.quran.foundation
QF_CONTENT_API_BASE=https://apis.quran.foundation
QF_USER_CLIENT_ID=your_qf_prelive_client_id
QF_USER_CLIENT_SECRET=your_qf_prelive_client_secret
QF_USER_OAUTH_BASE=https://prelive-oauth2.quran.foundation
QF_USER_API_BASE=https://apis-prelive.quran.foundation
